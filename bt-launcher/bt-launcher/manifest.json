{
  "manifest_version": 3,
  "name": "Based Trenches Launcher",
  "version": "1.0.0",
  "description": "Launch memecoins on Base Chain directly from your browser. Tokens appear on basedtrenches.fun instantly.",
  "icons": {
    "16":  "icons/trenchguard.png",
    "48":  "icons/trenchguard.png",
    "128": "icons/trenchguard.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/trenchguard.png",
    "default_title": "Based Trenches Launcher"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://mainnet.base.org/",
    "https://basedtrenches.fun/*",
    "https://www.basedtrenches.fun/*",
    "https://basedtrenches.co/*"
  ]
}
