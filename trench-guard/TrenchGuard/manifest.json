{
  "manifest_version": 3,
  "name": "Trench Guard",
  "version": "1.0.0",
  "description": "Protect your wallet on Base Chain. Scam detection, transaction warnings, and contract scanner. Free 30-day trial.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Trench Guard"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://basedtrenches.fun/*",
        "https://www.basedtrenches.fun/*",
        "https://basedtrenches.co/*",
        "https://www.basedtrenches.co/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "webNavigation",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://mainnet.base.org/",
    "https://api.basescan.org/*"
  ]
}
